# ------------------------------------------------------------
# NookMesh Runtime Configuration
# Controls export timing, visibility rules and map behaviour
# ------------------------------------------------------------

# ------------------------------------------------------------
# Timezone
# Used for human-readable timestamps in GeoJSON descriptions
# Does NOT affect UTC age calculations
# ------------------------------------------------------------
TIMEZONE=Europe/Madrid

# ------------------------------------------------------------
# Export scheduler
# How often the GeoJSON export is regenerated
# ------------------------------------------------------------
EXPORT_INTERVAL_SECONDS=3

# Export active hours (24h format)
# Supports overnight windows (example: 22 -> 6)
EXPORT_HOUR_START=6
EXPORT_HOUR_END=1

# ------------------------------------------------------------
# Visibility / freshness
# ------------------------------------------------------------

# Hide users older than this many minutes
# Color logic:
# Green   < 5 min
# Orange  5–29 min
# Red     30–60 min
# > MAX_EDAD_MIN = hidden
MAX_EDAD_MIN=60

# Hide the viewer's own position from the map output
EXCLUDE_VIEWER_IN_OUTPUT=true

# ------------------------------------------------------------
# Proximity filtering
# ------------------------------------------------------------

# Hide users closer than this distance to the viewer
EXCLUDE_NEARBY_METROS=80

# If true:
# viewer must have a recent position (<= MAX_EDAD_MIN)
# otherwise no other users will be shown
REQUIRE_RECENT_VIEWER_POSITION_FOR_PROXIMITY=true

# ------------------------------------------------------------
# Multi-device merge
# ------------------------------------------------------------

# Merge nearby devices belonging to the same user
MERGE_CLOSEST_DEVICES=true

# Maximum distance between devices to merge
MERGE_MAX_METROS=100

# ------------------------------------------------------------
# vi quick reference
# ------------------------------------------------------------
# Save + exit:    ESC :x
# Exit no save:   ESC :q!